<div id="nav-overlay">
  <ul class="ol-nav">
    <li><a href="#services" data-close><span class="ol-num">01</span>Services<span class="ol-arrow">↗</span></a></li>
    <li><a href="#work" data-close><span class="ol-num">02</span>Work<span class="ol-arrow">↗</span></a></li>
