    <a href="#contact" class="nav-link">Contact</a>
    <button class="theme-btn" id="theme-btn" aria-label="Toggle theme">
      <svg class="icon-moon" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      <svg class="icon-sun" viewBox="0 0 24 24"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    </button>
    <button class="nav-menu-btn" id="nav-menu-btn" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- HERO -->
<section id="hero">
  <canvas id="hero-canvas"></canvas>
  <div class="hero-noise"></div>

  <div class="hero-inner">
    <div class="hero-eyebrow">
      <div class="hero-eyebrow-line"></div>
      <span>Web Design Studio · Est. 2026</span>
    </div>
    <h1 class="hero-headline">
      <span class="line"><span class="word">WE BUILD</span></span>
      <span class="line"><span class="word lime">WEBSITES</span></span>
      <span class="line"><span class="word">THAT <span class="outline">WORK</span></span></span>
    </h1>
    <div class="hero-bottom">
      <p class="hero-desc">Custom websites and digital identities for businesses that want to stand out — handcrafted code, zero templates, built to convert.</p>
      <div class="hero-actions">
        <a href="#work" class="btn-lime">View Our Work</a>
        <a href="#contact" class="btn-outline">Start a Project</a>
      </div>
    </div>
  </div>

  <div class="hero-stats">
    <div class="h-stat">
      <div class="h-stat-num"><span class="count-up" data-target="15">0</span><span class="accent">+</span></div>
      <div class="h-stat-label">Projects Done</div>
    </div>
    <div class="h-stat">
      <div class="h-stat-num"><span class="count-up" data-target="48">0</span><span class="accent">h</span></div>
      <div class="h-stat-label">Avg Turnaround</div>
    </div>
    <div class="h-stat">
      <div class="h-stat-num"><span class="count-up" data-target="100">0</span><span class="accent">%</span></div>
      <div class="h-stat-label">Custom Code</div>
    </div>
  </div>

  <div class="hero-scroll">
    <div class="scroll-wheel"><div class="scroll-dot"></div></div>
    <div class="scroll-label">Scroll</div>
  </div>
</section>

<!-- MARQUEE -->
<div class="marquee-wrap">
  <div class="marquee-track">
    <div class="m-item">Restaurant Websites<span class="m-dot"></span></div>
    <div class="m-item">Digital Menus<span class="m-dot"></span></div>
    <div class="m-item">Business Sites<span class="m-dot"></span></div>
    <div class="m-item">Landing Pages<span class="m-dot"></span></div>
    <div class="m-item">Brand Identity<span class="m-dot"></span></div>
    <div class="m-item">Portfolio Sites<span class="m-dot"></span></div>
    <div class="m-item">Mobile First<span class="m-dot"></span></div>
    <div class="m-item">Pure Custom Code<span class="m-dot"></span></div>
    <div class="m-item">Restaurant Websites<span class="m-dot"></span></div>
    <div class="m-item">Digital Menus<span class="m-dot"></span></div>
    <div class="m-item">Business Sites<span class="m-dot"></span></div>
    <div class="m-item">Landing Pages<span class="m-dot"></span></div>
    <div class="m-item">Brand Identity<span class="m-dot"></span></div>
    <div class="m-item">Portfolio Sites<span class="m-dot"></span></div>
    <div class="m-item">Mobile First<span class="m-dot"></span></div>
    <div class="m-item">Pure Custom Code<span class="m-dot"></span></div>
  </div>
</div>

<!-- SERVICES -->
<section id="services" class="section">
  <div class="services-header">
    <div>
      <div class="s-eyebrow"><div class="s-eyebrow-line"></div><span>// What We Do</span></div>
      <div class="s-title">
        <div class="clip-reveal"><span class="clip-inner">WHAT</span></div>
        <div class="clip-reveal"><span class="clip-inner">WE DO</span></div>
      </div>
    </div>
    <p class="services-desc">Every project is built from scratch around your business — unique design, handcrafted code, no page builders, no templates. Just clean work that performs.</p>
  </div>

  <div class="services-list">
    <div class="service-item">
      <div class="service-num">01</div>
      <div>
        <div class="service-name">Restaurant & Café Websites</div>
        <div class="service-body">Full custom websites for food & beverage brands — digital menus, gallery, booking links, and a visual identity that matches your space.</div>
      </div>
      <div class="service-tags"><span class="s-tag">Design</span><span class="s-tag">Dev</span></div>
    </div>
    <div class="service-item">
      <div class="service-num">02</div>
      <div>
        <div class="service-name">Business Landing Pages</div>
        <div class="service-body">High-converting single pages for any type of business — fast, mobile-perfect, with a clear path to action that turns visitors into customers.</div>
      </div>
      <div class="service-tags"><span class="s-tag">Design</span><span class="s-tag">Dev</span></div>
    </div>
    <div class="service-item">
      <div class="service-num">03</div>
      <div>
        <div class="service-name">Portfolio & Personal Sites</div>
        <div class="service-body">Showcase your work with a sleek personal portfolio — animated, scroll-driven, and built to make a lasting impression on potential clients.</div>
      </div>
      <div class="service-tags"><span class="s-tag">Design</span><span class="s-tag">Dev</span></div>
    </div>
    <div class="service-item">
      <div class="service-num">04</div>
      <div>
        <div class="service-name">Digital Menus</div>
        <div class="service-body">Turn your static menu into a beautiful, mobile-friendly web experience — always up to date, no printing costs, easy to share via QR code.</div>
      </div>
      <div class="service-tags"><span class="s-tag">Design</span><span class="s-tag">Dev</span></div>
    </div>
