<!-- PROCESS -->
<section id="process" class="section">
  <div class="s-eyebrow"><div class="s-eyebrow-line"></div><span>// How We Work</span></div>
  <div class="s-title">
    <div class="clip-reveal"><span class="clip-inner">THE</span></div>
    <div class="clip-reveal"><span class="clip-inner">PROCESS</span></div>
  </div>
  <div class="process-grid">
    <div class="p-step">
      <div class="p-num">01</div>
      <div class="p-title">Discover</div>
      <div class="p-body">We start with a conversation — your business, your goals, your audience. We learn what makes you different before touching a single pixel.</div>
      <div class="p-tag">Strategy</div>
    </div>
    <div class="p-step">
      <div class="p-num">02</div>
      <div class="p-title">Design</div>
      <div class="p-body">We craft a visual language tailored to your brand — typography, color, layout, and interactions that feel uniquely yours.</div>
      <div class="p-tag">Aesthetics</div>
    </div>
    <div class="p-step">
      <div class="p-num">03</div>
      <div class="p-title">Build</div>
      <div class="p-body">Pure handcrafted code. No page builders, no WordPress, no templates. Clean HTML, CSS, and JS that loads fast on every device.</div>
      <div class="p-tag">Development</div>
    </div>
    <div class="p-step">
      <div class="p-num">04</div>
      <div class="p-title">Launch</div>
      <div class="p-body">We handle deployment, final testing across all devices, and make sure everything is perfect before going live. Then we stay close.</div>
      <div class="p-tag">Delivery</div>
    </div>
