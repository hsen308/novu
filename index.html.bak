<!-- FOOTER -->
<footer>
  <div class="footer-left">
    <svg width="22" height="22" viewBox="0 0 48 48" fill="none">
      <rect x="1" y="1" width="46" height="46" rx="10" stroke="var(--border-mid)" stroke-width="1.5"/>
      <rect x="12" y="13" width="5.5" height="22" rx="1" fill="var(--off)"/>
      <rect x="30.5" y="13" width="5.5" height="22" rx="1" fill="var(--off)"/>
      <path d="M17.5 13 L30.5 35" stroke="#c8ff00" stroke-width="5" stroke-linecap="round"/>
    </svg>
    <span class="footer-copy">© <span id="year"></span> Nova Studios. All rights reserved.</span>
  </div>
  <div class="footer-links">
    <a href="https://instagram.com/studiosnova" target="_blank" rel="noopener" class="footer-link">Instagram</a>
    <a href="https://wa.me/96170786131" target="_blank" rel="noopener" class="footer-link">WhatsApp</a>
    <a href="mailto:novastudios@gmail.com" class="footer-link">Email</a>
  </div>
</footer>

<script>
/* ══════════════════════════════════════════
   INIT
══════════════════════════════════════════ */
gsap.registerPlugin(ScrollTrigger);

const html = document.documentElement;
const preloader = document.getElementById('preloader');
const preNum = document.getElementById('pre-num');
const preBar = document.getElementById('pre-bar');
const preLogo = document.getElementById('pre-logo');
const isTouch = window.matchMedia('(hover: none)').matches;

/* ══════════════════════════════════════════
   PRELOADER
══════════════════════════════════════════ */
let count = 0;
const interval = setInterval(() => {
  count += Math.floor(Math.random() * 5) + 2;
  if (count >= 100) count = 100;
  preNum.textContent = count;
  preBar.style.width = count + '%';
  if (count === 100) {
    clearInterval(interval);
    setTimeout(() => {
      gsap.to(preloader, {
        opacity: 0, duration: 0.55, ease: 'power2.inOut',
        onComplete: () => {
          preloader.style.display = 'none';
          document.body.style.overflow = '';
          initHeroAnim();
        }
      });
    }, 280);
  }
}, 24);

setTimeout(() => { preLogo.classList.add('show'); }, 180);
document.body.style.overflow = 'hidden';

/* ══════════════════════════════════════════
   SCROLL PROGRESS BAR
══════════════════════════════════════════ */
const scrollBar = document.getElementById('scroll-progress');
window.addEventListener('scroll', () => {
  const max = document.body.scrollHeight - window.innerHeight;
  scrollBar.style.width = (window.scrollY / max * 100) + '%';
}, { passive: true });

/* ══════════════════════════════════════════
   HERO CANVAS (dot grid with glow pulse)
══════════════════════════════════════════ */
(function() {
  const canvas = document.getElementById('hero-canvas');
  const ctx = canvas.getContext('2d');
  let mouse = { x: -999, y: -999 };
  let dots = [], frame = 0;

  function resize() {
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight;
    buildDots();
  }

  function buildDots() {
    dots = [];
    const gap = isTouch ? 56 : 44;
    for (let x = gap; x < canvas.width; x += gap) {
      for (let y = gap; y < canvas.height; y += gap) {
        dots.push({ x, y, ox: x, oy: y, phase: Math.random() * Math.PI * 2 });
      }
    }
  }

  function draw() {
    frame++;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    const isDark = html.getAttribute('data-theme') !== 'light';
    dots.forEach(d => {
      const dx = mouse.x - d.ox;
      const dy = mouse.y - d.oy;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const radius = 140;
      if (dist < radius && !isTouch) {
        const force = (1 - dist / radius) * 12;
        d.x += (d.ox - (dx / dist) * force - d.x) * 0.18;
        d.y += (d.oy - (dy / dist) * force - d.y) * 0.18;
      } else {
        d.x += (d.ox - d.x) * 0.1;
        d.y += (d.oy - d.y) * 0.1;
      }
      const pulse = 0.5 + 0.5 * Math.sin(frame * 0.018 + d.phase);
      const baseAlpha = isDark ? 0.08 : 0.06;
      const r = dist < radius && !isTouch ? 1.5 : 1;
      ctx.beginPath();
      ctx.arc(d.x, d.y, r, 0, Math.PI * 2);
      ctx.fillStyle = isDark
        ? `rgba(200,255,0,${baseAlpha + pulse * 0.06})`
        : `rgba(90,150,0,${baseAlpha + pulse * 0.04})`;
      ctx.fill();
    });
    requestAnimationFrame(draw);
  }

  window.addEventListener('mousemove', e => {
    const rect = canvas.getBoundingClientRect();
    mouse.x = e.clientX - rect.left;
    mouse.y = e.clientY - rect.top;
  });

  window.addEventListener('resize', resize);
  resize();
  draw();
})();

/* ══════════════════════════════════════════
   CHAR SPLIT — hero headline
══════════════════════════════════════════ */
function splitChars(el) {
  el.querySelectorAll('.word').forEach(word => {
    const text = word.textContent;
    // check for nested spans (outline/lime)
    if (word.children.length) return;
    word.innerHTML = text.split('').map(c =>
      c === ' ' ? ' ' : `<span class="char">${c}</span>`
    ).join('');
  });
}
splitChars(document.querySelector('.hero-headline'));

/* ══════════════════════════════════════════
   HERO ANIMATION
══════════════════════════════════════════ */
function initHeroAnim() {
  const tl = gsap.timeline({ defaults: { ease: 'power4.out' } });

  tl.to('.hero-eyebrow-line', { scaleX: 1, duration: 0.7 })
    .to('.hero-eyebrow span', { y: 0, duration: 0.55 }, '-=0.35')
    .to('.char', {
      y: 0, opacity: 1, duration: 0.75, stagger: 0.022,
      ease: 'power3.out'
    }, '-=0.25')
    // fallback for .word spans with children
    .to('.hero-headline .word', { y: 0, duration: 0.7, stagger: 0.1 }, '<')
    .to('.hero-desc', { opacity: 1, y: 0, duration: 0.7 }, '-=0.4')
    .to('.hero-actions', { opacity: 1, y: 0, duration: 0.7 }, '-=0.55')
    .to('.hero-stats', { opacity: 1, duration: 0.7 }, '-=0.55')
    .to('.hero-scroll', { opacity: 1, duration: 0.5 }, '-=0.3');

  // Count-up
  document.querySelectorAll('.count-up').forEach(el => {
    const target = +el.dataset.target;
    ScrollTrigger.create({
      trigger: el, start: 'top 85%', once: true,
      onEnter: () => {
        let n = 0;
        const step = () => {
          n = Math.min(n + Math.ceil(target / 36), target);
          el.textContent = n;
          if (n < target) requestAnimationFrame(step);
        };
        step();
      }
    });
  });
}

/* ══════════════════════════════════════════
   HERO PARALLAX ON SCROLL
══════════════════════════════════════════ */
if (!isTouch) {
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    const heroInner = document.querySelector('.hero-inner');
    const heroStats = document.querySelector('.hero-stats');
    if (heroInner) heroInner.style.transform = `translateY(${y * 0.18}px)`;
    if (heroStats) heroStats.style.transform = `translateY(calc(-50% + ${y * 0.1}px))`;
  }, { passive: true });
}

/* ══════════════════════════════════════════
   CURSOR
══════════════════════════════════════════ */
if (!isTouch) {
  const cur = document.getElementById('cur');
  const curRing = document.getElementById('cur-ring');
  let cx = 0, cy = 0, rx = 0, ry = 0;

  document.addEventListener('mousemove', e => {
    cx = e.clientX; cy = e.clientY;
    cur.style.left = cx + 'px';
    cur.style.top = cy + 'px';
  });

  (function movRing() {
    rx += (cx - rx) * 0.13;
    ry += (cy - ry) * 0.13;
    curRing.style.left = rx + 'px';
    curRing.style.top = ry + 'px';
    requestAnimationFrame(movRing);
  })();

  document.querySelectorAll('a,button,.work-card,.service-item,.p-step,.t-card,.about-tag').forEach(el => {
    el.addEventListener('mouseenter', () => document.body.classList.add('hovering'));
    el.addEventListener('mouseleave', () => document.body.classList.remove('hovering'));
  });
}

/* ══════════════════════════════════════════
   MAGNETIC BUTTONS
══════════════════════════════════════════ */
if (!isTouch) {
  document.querySelectorAll('.btn-lime, .btn-outline').forEach(btn => {
    btn.addEventListener('mousemove', e => {
      const r = btn.getBoundingClientRect();
      const dx = e.clientX - (r.left + r.width / 2);
      const dy = e.clientY - (r.top + r.height / 2);
      btn.style.transform = `translate(${dx * 0.28}px, ${dy * 0.28}px) translateY(-3px)`;
    });
    btn.addEventListener('mouseleave', () => {
      btn.style.transform = '';
    });
  });
}

/* ══════════════════════════════════════════
   WORK CARD 3D TILT
══════════════════════════════════════════ */
if (!isTouch) {
  document.querySelectorAll('.work-card').forEach(card => {
    card.addEventListener('mousemove', e => {
      const r = card.getBoundingClientRect();
      const x = (e.clientX - r.left) / r.width - 0.5;
      const y = (e.clientY - r.top) / r.height - 0.5;
      card.style.transform = `rotateY(${x * 8}deg) rotateX(${-y * 6}deg) scale(1.02)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = '';
    });
  });
}

/* ══════════════════════════════════════════
   NAV
══════════════════════════════════════════ */
const nav = document.getElementById('nav');
const menuBtn = document.getElementById('nav-menu-btn');
const overlay = document.getElementById('nav-overlay');
let menuOpen = false;

window.addEventListener('scroll', () => {
  nav.classList.toggle('stuck', window.scrollY > 40);
}, { passive: true });

function toggleMenu() {
  menuOpen = !menuOpen;
  menuBtn.classList.toggle('open', menuOpen);
  overlay.classList.toggle('open', menuOpen);
  document.body.style.overflow = menuOpen ? 'hidden' : '';
}
menuBtn.addEventListener('click', toggleMenu);
document.querySelectorAll('[data-close]').forEach(a => {
  a.addEventListener('click', () => { if (menuOpen) toggleMenu(); });
});

// Smooth anchor scroll with offset
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const target = document.querySelector(a.getAttribute('href'));
    if (!target) return;
    e.preventDefault();
    const offset = 0;
    const top = target.getBoundingClientRect().top + window.scrollY - offset;
    window.scrollTo({ top, behavior: 'smooth' });
  });
});

/* ══════════════════════════════════════════
   ACTIVE NAV LINK ON SCROLL
══════════════════════════════════════════ */
const navLinks = document.querySelectorAll('.nav-link');
const sections = [...navLinks].map(l => document.querySelector(l.getAttribute('href'))).filter(Boolean);

window.addEventListener('scroll', () => {
  let current = '';
  sections.forEach(s => {
    if (window.scrollY >= s.offsetTop - 120) current = '#' + s.id;
  });
  navLinks.forEach(l => l.classList.toggle('active', l.getAttribute('href') === current));
}, { passive: true });

/* ══════════════════════════════════════════
   THEME TOGGLE
══════════════════════════════════════════ */
const themeBtn = document.getElementById('theme-btn');

function applyTheme(theme) {
  html.setAttribute('data-theme', theme);
  localStorage.setItem('nova-theme', theme);
}

const savedTheme = localStorage.getItem('nova-theme');
if (savedTheme) applyTheme(savedTheme);

themeBtn.addEventListener('click', () => {
  applyTheme(html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
});

/* ══════════════════════════════════════════
   SCROLL REVEALS — clip
══════════════════════════════════════════ */
document.querySelectorAll('.clip-reveal').forEach(el => {
  ScrollTrigger.create({
    trigger: el, start: 'top 88%', once: true,
    onEnter: () => el.classList.add('revealed')
  });
});

/* Staggered fade for service items */
gsap.utils.toArray('.service-item').forEach((el, i) => {
  gsap.fromTo(el,
    { opacity: 0, x: -20 },
    { opacity: 1, x: 0, duration: 0.65, delay: i * 0.07, ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 90%', once: true } }
  );
});

/* Process steps */
gsap.utils.toArray('.p-step').forEach((el, i) => {
  gsap.fromTo(el,
    { opacity: 0, y: 40, scale: 0.96 },
    { opacity: 1, y: 0, scale: 1, duration: 0.7, delay: (i % 4) * 0.1, ease: 'back.out(1.4)',
      scrollTrigger: { trigger: el, start: 'top 88%', once: true } }
  );
});

/* Testimonial cards */
gsap.utils.toArray('.t-card').forEach((el, i) => {
  gsap.fromTo(el,
    { opacity: 0, y: 30 },
    { opacity: 1, y: 0, duration: 0.7, delay: i * 0.12, ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 88%', once: true } }
  );
});

/* About section */
gsap.fromTo('.about-card',
  { opacity: 0, x: -50, rotationY: -8 },
  { opacity: 1, x: 0, rotationY: 0, duration: 1, ease: 'power3.out',
    scrollTrigger: { trigger: '#about', start: 'top 78%', once: true } }
);
gsap.fromTo('.about-right',
  { opacity: 0, x: 50 },
  { opacity: 1, x: 0, duration: 1, delay: 0.15, ease: 'power3.out',
    scrollTrigger: { trigger: '#about', start: 'top 78%', once: true } }
);

/* Work cards stagger reveal */
gsap.fromTo('.work-card',
  { opacity: 0, y: 24 },
  { opacity: 1, y: 0, duration: 0.7, stagger: 0.1, ease: 'power3.out',
    scrollTrigger: { trigger: '#work', start: 'top 85%', once: true } }
);

/* Contact */
gsap.fromTo('.contact-big',
  { opacity: 0, y: 40 },
  { opacity: 1, y: 0, duration: 0.9, ease: 'power4.out',
    scrollTrigger: { trigger: '#contact', start: 'top 82%', once: true } }
);
gsap.fromTo('.contact-sub, .contact-actions, .contact-info',
  { opacity: 0, y: 20 },
  { opacity: 1, y: 0, duration: 0.7, stagger: 0.1, delay: 0.2, ease: 'power3.out',
    scrollTrigger: { trigger: '#contact', start: 'top 82%', once: true } }
);

/* Process glow line */
gsap.fromTo('#process::before', {}, {});
gsap.fromTo('.process-grid',
  { opacity: 0 },
  { opacity: 1, duration: 0.5,
    scrollTrigger: { trigger: '#process', start: 'top 80%', once: true } }
);

/* ══════════════════════════════════════════
   SKILL BARS
══════════════════════════════════════════ */
ScrollTrigger.create({
  trigger: '.about-bars', start: 'top 85%', once: true,
  onEnter: () => {
    document.querySelectorAll('.a-bar-fill').forEach(bar => {
      bar.style.width = bar.dataset.width + '%';
    });
  }
});

/* ══════════════════════════════════════════
   WORK TRACK — DRAG (desktop) + TOUCH (mobile)
══════════════════════════════════════════ */
const track = document.getElementById('work-track');
let isDragging = false, startX = 0, scrollLeft = 0, velocity = 0, lastX = 0;

track.addEventListener('mousedown', e => {
  isDragging = true; track.style.cursor = 'grabbing';
  startX = e.pageX - track.offsetLeft;
  scrollLeft = track.scrollLeft;
  lastX = e.pageX;
});
document.addEventListener('mouseup', () => {
  isDragging = false; track.style.cursor = 'grab';
  // momentum
  let v = velocity;
  const momentum = () => {
    if (Math.abs(v) < 0.5) return;
    track.scrollLeft -= v;
    v *= 0.92;
    requestAnimationFrame(momentum);
  };
  momentum();
});
track.addEventListener('mousemove', e => {
  if (!isDragging) return;
  e.preventDefault();
  const x = e.pageX - track.offsetLeft;
  velocity = lastX - e.pageX;
  lastX = e.pageX;
  track.scrollLeft = scrollLeft - (x - startX);
});

// Touch: let native scroll handle it (snap already set in CSS)
track.addEventListener('touchstart', e => { scrollLeft = track.scrollLeft; }, { passive: true });

/* ══════════════════════════════════════════
   MARQUEE HOVER PAUSE (already in CSS but
   also pause on touch for accessibility)
══════════════════════════════════════════ */

/* ══════════════════════════════════════════
   FOOTER YEAR
══════════════════════════════════════════ */
document.getElementById('year').textContent = new Date().getFullYear();
</script>
</body>
</html>
